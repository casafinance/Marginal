{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marginal",
  "version": "1.0.2",
  "identifier": "com.marginal.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Marginal",
        "width": 1200,
        "height": 850,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "Open with Marginal",
        "role": "Editor"
      }
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YOUR_GITHUB_USERNAME/marginal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5OTgzOTJENzFDN0EwMEMKUldRTW9NZHhMVG1ZdWF1eE1mcy8vbXBBYXNLam8rMmpvNlhHMHA4dGVKYXB6Tjg4Y3JFOWdvYkgK"
    }
  }
}
